{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/openapi.json",
      "destination": "https://ensaraslannn-001-site1.ctempurl.com/openapi.json"
    },
    {
      "source": "/api/api/:path*",
      "destination": "https://ensaraslannn-001-site1.ctempurl.com/api/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://ensaraslannn-001-site1.ctempurl.com/api/:path*"
    },
    {
      "source": "/((?!api-doc|assets|openapi\\.json).*)" ,
      "destination": "/index.html"
    }
  ]
}